<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetHealthRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widgetHealthTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_health_title"
        android:textColor="#20342D"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetHealthScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_no_score"
        android:textColor="#5BB89A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetHealthSummary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_weight="1"
        android:text="@string/widget_empty_today"
        android:textColor="#5E716A"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widgetHealthOpen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_light"
            android:gravity="center"
            android:text="@string/widget_open_calendar"
            android:textColor="#20342D"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetHealthPoo"
            android:layout_width="76dp"
            android:layout_height="match_parent"
            android:background="@drawable/widget_button_mint"
            android:gravity="center"
            android:text="@string/widget_poo"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
